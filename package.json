{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "dev:capacitor": "vite --config vite.capacitor.config.ts --host --port 5173 --strictPort",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "schema:generate": "php artisan lighthouse:print-schema --sort --no-ansi > graphql/schema.generated.graphql",
        "codegen": "npm run schema:generate && graphql-codegen --config codegen.ts",
        "cap:build": "vite build --config vite.capacitor.config.ts",
        "cap:init": "npx cap init",
        "cap:sync": "npm run cap:build && npx cap sync",
        "cap:run:ios": "npx cap run ios --no-sync",
        "cap:run:ios:live": "npx cap run ios --no-sync -l --host=localhost --port=5173",
        "cap:open:ios": "npx cap open ios",
        "cap:open:android": "npx cap open android"
    },
    "devDependencies": {
        "@capacitor/cli": "^8.1.0",
        "@graphql-codegen/cli": "^6.1.1",
        "@graphql-codegen/near-operation-file-preset": "^4.0.0",
        "@graphql-codegen/typed-document-node": "^6.1.5",
        "@graphql-codegen/typescript": "^5.0.7",
        "@graphql-codegen/typescript-operations": "^5.0.7",
        "@tailwindcss/vite": "^4.0.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "axios": "^1.11.0",
        "babel-plugin-react-compiler": "^1.0.0",
        "concurrently": "^9.0.1",
        "jsdom": "^27.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "msw": "^2.12.10",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "shadcn": "^3.8.4",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.9.3",
        "vite": "^7.0.7",
        "vitest": "^3.2.4"
    },
    "dependencies": {
        "@apollo/client": "^4.1.4",
        "@capacitor/core": "^8.1.0",
        "@capacitor/ios": "^8.1.0",
        "@radix-ui/react-slot": "^1.2.4",
        "capacitor-secure-storage-plugin": "^0.13.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "graphql": "^16.12.0",
        "input-otp": "^1.4.2",
        "lucide-react": "^0.564.0",
        "radix-ui": "^1.4.3",
        "tailwind-merge": "^3.4.0",
        "tw-animate-css": "^1.4.0",
        "wouter": "^3.9.0",
        "zustand": "^5.0.11"
    }
}
